generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id         String    @id @default(cuid())
  title      String
  status     String    @default("active")
  priority   String    @default("medium")
  notes      String?
  dueDate    DateTime?
  nextAction String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model LegalItem {
  id          String    @id @default(cuid())
  title       String
  type        String    @default("other")
  status      String    @default("pending")
  deadline    DateTime?
  notes       String?
  documentRef String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model FinancialItem {
  id        String    @id @default(cuid())
  title     String
  category  String    @default("expense")
  status    String    @default("active")
  amount    Float?
  frequency String?
  notes     String?
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  status    String   @default("pending")
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ContactInquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  inquiryType String
  message     String?
  details     String?
  status      String   @default("new")
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model Booking {
  id        String    @id @default(cuid())
  title     String
  dateTime  DateTime
  endTime   DateTime?
  location  String?
  status    String    @default("confirmed")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([dateTime])
  @@index([createdAt])
}

model Performance {
  id          String   @id @default(cuid())
  title       String
  persona     String?
  venue       String?
  date        DateTime
  hoursWorked Float?
  type        String   @default("featured")
  season      String   @default("standard")
  status      String   @default("scheduled")
  brandScore  Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incomes     PerformanceIncome[]
  expenses    PerformanceExpense[]
  assetUsages AssetUsage[]

  @@index([date])
  @@index([status])
  @@index([persona])
  @@index([type])
  @@index([season])
}

model PerformanceIncome {
  id            String      @id @default(cuid())
  performanceId String
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  category      String
  amount        Float
  isProjected   Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([performanceId])
  @@index([category])
}

model PerformanceExpense {
  id            String      @id @default(cuid())
  performanceId String
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  category      String
  amount        Float
  isProjected   Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([performanceId])
  @@index([category])
}

model Asset {
  id           String       @id @default(cuid())
  name         String
  category     String
  purchaseCost Float
  purchaseDate DateTime
  expectedUses Int          @default(10)
  status       String       @default("active")
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  usages AssetUsage[]

  @@index([category])
  @@index([status])
}

model AssetUsage {
  id            String      @id @default(cuid())
  performanceId String
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([performanceId, assetId])
  @@index([performanceId])
  @@index([assetId])
}

model Directive {
  id          String           @id @default(cuid())
  instruction String
  status      String           @default("pending")
  targetPath  String?
  branch      String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  claimedAt   DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  result      DirectiveResult?

  @@index([status])
  @@index([createdAt])
}

model DirectiveResult {
  id          String   @id @default(cuid())
  directiveId String   @unique
  directive   Directive @relation(fields: [directiveId], references: [id], onDelete: Cascade)
  success     Boolean
  exitCode    Int?
  stdout      String
  stderr      String
  summary     String
  startedAt   DateTime
  completedAt DateTime
  durationMs  Int
  truncated   Boolean  @default(false)
  error       String?
}
