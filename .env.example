# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_TRUST_HOST=true

# Site Administrator (username/password login — admin-only access)
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD="your-admin-password"

# Google OAuth (set up at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# SendGrid
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="delivery@mail.housofthedarlingstarling.com"
SENDGRID_FROM_NAME="Hous of The Darling Starling"
